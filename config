#!/usr/bin/env bash
# ══════════════════════════════════════════════════════════════════════════════
#  config  ─  Unified configure / build / install for cbc-workspace
#
#  Configures, in strict dependency order, the 5-project COIN-OR stack:
#    CoinUtils -> Osi -> Clp -> Cgl -> Cbc
#  into one shared install prefix (later projects discover earlier ones via
#  pkg-config .pc files).
#
#  Usage (non-interactive):
#    ./config [OPTIONS]
#
#  Usage (interactive TUI – run with no arguments on a terminal):
#    ./config
#    ./config --interactive
#
#  Options:
#   Build mode:
#     --opt                    Optimised build (-O3)          [default]
#     --debug                  Debug build (-O1 -g)
#
#   Sanitiser (debug only):
#     --sanitizer=none         No sanitiser                   [default]
#     --sanitizer=asan         AddressSanitizer
#     --sanitizer=tsan         ThreadSanitizer
#     --sanitizer=valgrind     Valgrind-friendly (no ASan/TSan, keeps frame ptrs)
#
#   Compiler optimisations:
#     --arch=native            -march=native -mtune=native            [default]
#     --arch=generic           No -march/-mtune (compiler default baseline)
#     --arch=<preset>          A named milestone preset (see below)
#     --march-native           Alias for --arch=native  (legacy)
#     --no-march-native        Alias for --arch=generic (legacy)
#
#     x86_64 presets   : sandybridge (AVX, 2011) | haswell (AVX2+FMA, 2013)
#                        | skylake-avx512 (AVX-512, 2017)
#     aarch64 presets  : cortex-a72 (ARMv8.0, e.g. RPi4)
#                        | neoverse-n1 (ARMv8.2, e.g. AWS Graviton2)
#                        | neoverse-v1 (ARMv8.4+SVE, e.g. AWS Graviton3)
#
#     -ffp-contract=off is ALWAYS added (any --arch value) for reproducible,
#     stable floating-point results (no silent FMA contraction).
#
#     --avx2                   -DCOIN_AVX2=4 (x86_64 only)   [default: OFF]
#     --no-avx2                Omit -DCOIN_AVX2=4 (default)
#
#   Optional dependencies (only shown/usable when detected on the system):
#     --lapack / --no-lapack    LAPACK/BLAS (prefers OpenBLAS)     [default: on if found]
#     --amd / --no-amd          SuiteSparse AMD ordering (Clp Cholesky) [default: on if found]
#     --zlib / --no-zlib        .gz compressed MPS/LP I/O          [default: on if found]
#     --bz2 / --no-bz2          .bz2 compressed MPS/LP I/O         [default: on if found]
#     --nauty / --no-nauty      Graph automorphism (Cbc symmetry)  [default: on if found]
#
#     Detection prefers Homebrew libraries when the selected compiler is
#     itself a Homebrew compiler; otherwise system libraries are used.
#
#   Library type:
#     --static                 Static libs only               [default]
#     --shared                 Shared libs only
#     --both                   Both static and shared
#
#   Install / build:
#     --prefix=PATH             Install prefix   [default: ~/prog/cbc]
#     --jobs=N                  Parallel make jobs for every project [default: nproc]
#     --build                   Configure + build (no install)
#     --install                 Configure + build + install
#     --interactive, -i          Force TUI even when arguments are given
#     --dry-run                  Print commands without running them
#     --help, -h                  Show this help
# ══════════════════════════════════════════════════════════════════════════════
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"
WORKSPACE_DIR="$SCRIPT_DIR"
SRC_DIR="$WORKSPACE_DIR"
ARCH="$(uname -m)"
[[ "$ARCH" == "arm64" ]] && ARCH="aarch64"
NPROC="$(nproc 2>/dev/null || echo 4)"
PROJECTS=(CoinUtils Osi Clp Cgl Cbc)

# ── Architecture target presets ──────────────────────────────────────────────
# Besides "native" and "generic" (no arch flags), offer 3 named milestones per
# architecture. These are real -march values recognised by GCC/Clang, chosen
# to reflect meaningful hardware generations rather than abstract ISA levels.
_arch_choices() {
  case "$ARCH" in
    x86_64)  echo "sandybridge haswell skylake-avx512" ;;
    aarch64) echo "cortex-a72 neoverse-n1 neoverse-v1" ;;
    *) : ;;
  esac
}

_arch_label() {
  case "$1" in
    native)          echo "Native  (-march=native -mtune=native, tuned for this CPU)" ;;
    generic)         echo "Generic  (no -march/-mtune, compiler baseline)" ;;
    sandybridge)     echo "Sandy Bridge  (AVX, 2011)" ;;
    haswell)         echo "Haswell  (AVX2 + FMA + BMI2, 2013)" ;;
    skylake-avx512)  echo "Skylake-X  (AVX-512, 2017)" ;;
    cortex-a72)      echo "Cortex-A72  (ARMv8.0, e.g. Raspberry Pi 4)" ;;
    neoverse-n1)     echo "Neoverse N1  (ARMv8.2, e.g. AWS Graviton2)" ;;
    neoverse-v1)     echo "Neoverse V1  (ARMv8.4 + SVE, e.g. AWS Graviton3)" ;;
    *)               echo "$1" ;;
  esac
}

# ── ANSI colours (auto-disabled when not a terminal) ─────────────────────────
if [[ -t 1 ]]; then
  BOLD=$'\e[1m';  RESET=$'\e[0m';   DIM=$'\e[2m'
  RED=$'\e[31m';  GREEN=$'\e[32m';  YELLOW=$'\e[33m'
  CYAN=$'\e[36m'; MAGENTA=$'\e[35m'; BLUE=$'\e[34m'
else
  BOLD=''; RESET=''; DIM=''; RED=''; GREEN=''
  YELLOW=''; CYAN=''; MAGENTA=''; BLUE=''
fi

# ── Defaults ─────────────────────────────────────────────────────────────────
OPT_BUILD_MODE="opt"       # opt | debug
OPT_SANITIZER="none"       # none | asan | tsan | valgrind
OPT_ARCH="native"          # generic | native | <named preset, see _arch_choices>
OPT_AVX2=0                 # 1=on 0=off  (only applies on x86_64; adds -DCOIN_AVX2=4)

# Optional dependencies. -1 = "unset" (use detected availability as default);
# explicitly set to 0/1 once the user (CLI flag or TUI) has made a choice.
OPT_LAPACK=-1
OPT_AMD=-1
OPT_ZLIB=-1
OPT_BZ2=-1
OPT_NAUTY=-1

OPT_LIB_TYPE="static"      # static | shared | both
OPT_PREFIX=""              # auto-derived if empty
OPT_JOBS="$NPROC"
OPT_DO_BUILD=0
OPT_DO_INSTALL=0
OPT_DRY_RUN=0
OPT_INTERACTIVE=0
_ARGS_GIVEN=0              # track whether any CLI args were provided

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
  grep '^#  ' "${BASH_SOURCE[0]}" | sed 's/^#  //'
}

# ── Parse CLI arguments ───────────────────────────────────────────────────────
parse_args() {
  local -a unknown=()
  for arg in "$@"; do
    _ARGS_GIVEN=1
    case "$arg" in
      --opt)               OPT_BUILD_MODE="opt"  ;;
      --debug)             OPT_BUILD_MODE="debug" ;;
      --sanitizer=*)       OPT_SANITIZER="${arg#--sanitizer=}" ;;
      --arch=*)            OPT_ARCH="${arg#--arch=}" ;;
      --march-native)      OPT_ARCH="native" ;;
      --no-march-native)   OPT_ARCH="generic" ;;
      --avx2)              OPT_AVX2=1 ;;
      --no-avx2)           OPT_AVX2=0 ;;
      --lapack)            OPT_LAPACK=1 ;;
      --no-lapack)         OPT_LAPACK=0 ;;
      --amd)               OPT_AMD=1 ;;
      --no-amd)            OPT_AMD=0 ;;
      --zlib)              OPT_ZLIB=1 ;;
      --no-zlib)           OPT_ZLIB=0 ;;
      --bz2)               OPT_BZ2=1 ;;
      --no-bz2)            OPT_BZ2=0 ;;
      --nauty)             OPT_NAUTY=1 ;;
      --no-nauty)          OPT_NAUTY=0 ;;
      --static)            OPT_LIB_TYPE="static" ;;
      --shared)            OPT_LIB_TYPE="shared" ;;
      --both)              OPT_LIB_TYPE="both"   ;;
      --prefix=*)          OPT_PREFIX="${arg#--prefix=}" ;;
      --jobs=*)            OPT_JOBS="${arg#--jobs=}" ;;
      --build)             OPT_DO_BUILD=1 ;;
      --install)           OPT_DO_BUILD=1; OPT_DO_INSTALL=1 ;;
      --interactive|-i)    OPT_INTERACTIVE=1 ;;
      --dry-run)           OPT_DRY_RUN=1 ;;
      --help|-h)           usage; exit 0 ;;
      *) unknown+=("$arg") ;;
    esac
  done
  if [[ ${#unknown[@]} -gt 0 ]]; then
    echo "${RED}Unknown arguments: ${unknown[*]}${RESET}" >&2
    echo "Run '$SCRIPT_NAME --help' for usage." >&2
    exit 1
  fi
}

# ── Validation ────────────────────────────────────────────────────────────────
validate_opts() {
  case "$OPT_SANITIZER" in
    none|asan|tsan|valgrind) ;;
    *) echo "${RED}Invalid sanitizer '${OPT_SANITIZER}'. Use: none asan tsan valgrind${RESET}" >&2; exit 1 ;;
  esac
  case "$OPT_LIB_TYPE" in
    static|shared|both) ;;
    *) echo "${RED}Invalid library type '${OPT_LIB_TYPE}'. Use: static shared both${RESET}" >&2; exit 1 ;;
  esac
  if [[ ! "$OPT_JOBS" =~ ^[1-9][0-9]*$ ]]; then
    echo "${RED}Invalid jobs value '${OPT_JOBS}'. Must be a positive integer.${RESET}" >&2; exit 1
  fi
  case "$OPT_ARCH" in
    native|generic) ;;
    *)
      if ! [[ " $(_arch_choices) " == *" ${OPT_ARCH} "* ]]; then
        echo "${RED}Invalid --arch '${OPT_ARCH}' for ${ARCH}. Use: native generic $(_arch_choices)${RESET}" >&2
        exit 1
      fi
      ;;
  esac
  # AVX2 is x86_64-only — silently disable on other arches.
  # Use || form (not &&) so the expression always returns 0, avoiding a set -e
  # exit when the condition is false and the assignment is short-circuited.
  [[ "$ARCH" == "x86_64"  ]] || OPT_AVX2=0
}

# ── Derive install prefix if not set by user ──────────────────────────────────
derive_prefix() {
  [[ -n "$OPT_PREFIX" ]] && return
  local base="${CBC_WORKSPACE_PREFIX:-$HOME/prog/cbc}"
  case "$OPT_SANITIZER" in
    asan)     OPT_PREFIX="${base}-asan"  ;;
    tsan)     OPT_PREFIX="${base}-tsan" ;;
    valgrind) OPT_PREFIX="${base}-vg"   ;;
    *)
      if [[ "$OPT_BUILD_MODE" == "opt" ]]; then
        OPT_PREFIX="$base"
      else
        OPT_PREFIX="${base}-dbg"
      fi ;;
  esac
}

_project_dir() {
  echo "${SRC_DIR}/$1"
}

# ══════════════════════════════════════════════════════════════════════════════
#  Optional dependency detection (LAPACK/OpenBLAS, AMD, zlib, bz2, Nauty)
# ══════════════════════════════════════════════════════════════════════════════
#
#  Homebrew-aware: when the compiler resolved for this build lives under a
#  Homebrew prefix, we prefer Homebrew's copy of each optional library (if
#  installed) over the system copy, so the whole toolchain is consistent.
#  Otherwise the system's libraries/headers are used, same as plain autoconf
#  auto-detection.

BREW_PREFIX=""
USE_BREW_LIBS=0

LAPACK_AVAIL=0; LAPACK_LFLAGS=""; LAPACK_WHAT=""
AMD_AVAIL=0;    AMD_CFLAGS="";    AMD_LFLAGS=""
ZLIB_AVAIL=0;   ZLIB_CFLAGS="";   ZLIB_LFLAGS=""
BZ2_AVAIL=0;    BZ2_CFLAGS="";    BZ2_LFLAGS=""
NAUTY_AVAIL=0;  NAUTY_CFLAGS="";  NAUTY_LFLAGS=""

_pkgcfg() {
  command -v pkg-config &>/dev/null || return 1
  local pcpath="$1" flag="$2" pkg="$3"
  PKG_CONFIG_PATH="${pcpath}${PKG_CONFIG_PATH:+:${PKG_CONFIG_PATH}}" \
    pkg-config "$flag" "$pkg" 2>/dev/null
}

# Try to compile a 1-line program including $1, with extra flags $2.. .
_check_header() {
  local header="$1"; shift
  echo "#include <${header}>
int main(void){return 0;}" | "${CC:-cc}" "$@" -x c - -o /dev/null 2>/dev/null
  local rc=$?
  rm -f a.out 2>/dev/null
  return $rc
}

detect_optional_deps() {
  # ── Locate Homebrew (same probing order as the compiler search below) ─────
  if command -v brew &>/dev/null; then
    BREW_PREFIX="$(brew --prefix 2>/dev/null || true)"
  else
    local _bp
    for _bp in /home/linuxbrew/.linuxbrew /opt/homebrew /usr/local; do
      [[ -x "${_bp}/bin/brew" ]] && { BREW_PREFIX="$_bp"; break; }
    done
  fi

  # ── Is the compiler we will actually use a Homebrew compiler? ─────────────
  if [[ -n "$BREW_PREFIX" ]]; then
    local _cc_path
    _cc_path="$(command -v "${CC:-cc}" 2>/dev/null || true)"
    [[ "$_cc_path" == "${BREW_PREFIX}"/* ]] && USE_BREW_LIBS=1
  fi

  # ── LAPACK / OpenBLAS ──────────────────────────────────────────────────────
  # OpenBLAS is a faster drop-in that also provides LAPACK; prefer it over a
  # bare reference LAPACK/BLAS when found. Homebrew ships it as "openblas"
  # (not under the generic lapack.pc/blas.pc names autoconf looks for), so we
  # always pass explicit --with-lapack-lflags when using it.
  if (( USE_BREW_LIBS )) && [[ -d "${BREW_PREFIX}/opt/openblas" ]]; then
    LAPACK_AVAIL=1
    LAPACK_LFLAGS="$(_pkgcfg "${BREW_PREFIX}/opt/openblas/lib/pkgconfig" --libs openblas)"
    LAPACK_WHAT="Homebrew OpenBLAS"
  elif _pkgcfg "" --exists openblas && _pkgcfg "" --libs openblas &>/dev/null; then
    LAPACK_AVAIL=1
    LAPACK_LFLAGS="$(_pkgcfg "" --libs openblas)"
    LAPACK_WHAT="system OpenBLAS"
  elif _pkgcfg "" --exists "lapack blas" 2>/dev/null; then
    LAPACK_AVAIL=1
    LAPACK_WHAT="system LAPACK/BLAS"
    # No explicit lflags needed — CoinUtils' own configure auto-probes
    # lapack.pc/blas.pc via pkg-config.
  elif ldconfig -p 2>/dev/null | grep -q 'liblapack\.so'; then
    LAPACK_AVAIL=1
    LAPACK_WHAT="system LAPACK/BLAS"
  fi

  # ── AMD (SuiteSparse approximate minimum degree ordering; used by Clp's
  #    dense/CHOLMOD-based Cholesky factorisation) ────────────────────────────
  # pkg-config module name is "AMD" (SuiteSparse convention); Homebrew ships
  # it bundled in the "suite-sparse" formula rather than a standalone "amd"
  # formula, still exposing an AMD.pc under its own lib/pkgconfig.
  if (( USE_BREW_LIBS )) && [[ -n "$BREW_PREFIX" ]] && _pkgcfg "${BREW_PREFIX}/lib/pkgconfig:${BREW_PREFIX}/opt/suite-sparse/lib/pkgconfig" --exists AMD 2>/dev/null; then
    AMD_AVAIL=1
    AMD_CFLAGS="$(_pkgcfg "${BREW_PREFIX}/lib/pkgconfig:${BREW_PREFIX}/opt/suite-sparse/lib/pkgconfig" --cflags AMD)"
    AMD_LFLAGS="$(_pkgcfg "${BREW_PREFIX}/lib/pkgconfig:${BREW_PREFIX}/opt/suite-sparse/lib/pkgconfig" --libs AMD)"
  elif _pkgcfg "" --exists AMD 2>/dev/null; then
    AMD_AVAIL=1
    AMD_CFLAGS="$(_pkgcfg "" --cflags AMD)"
    AMD_LFLAGS="$(_pkgcfg "" --libs AMD)"
  elif (( USE_BREW_LIBS )) && [[ -n "$BREW_PREFIX" && -d "${BREW_PREFIX}/opt/suite-sparse" ]]; then
    AMD_AVAIL=1
    AMD_CFLAGS="-I${BREW_PREFIX}/opt/suite-sparse/include/suitesparse"
    AMD_LFLAGS="-L${BREW_PREFIX}/opt/suite-sparse/lib -lamd"
  elif _check_header suitesparse/amd.h; then
    AMD_AVAIL=1
    AMD_CFLAGS="-I/usr/include/suitesparse"
    AMD_LFLAGS="-lamd"
  elif [[ -n "$BREW_PREFIX" && -d "${BREW_PREFIX}/opt/suite-sparse" ]]; then
    AMD_AVAIL=1
    AMD_CFLAGS="-I${BREW_PREFIX}/opt/suite-sparse/include/suitesparse"
    AMD_LFLAGS="-L${BREW_PREFIX}/opt/suite-sparse/lib -lamd"
  fi

  # ── zlib (.gz support) ─────────────────────────────────────────────────────
  if (( USE_BREW_LIBS )) && [[ -d "${BREW_PREFIX}/opt/zlib" ]]; then
    ZLIB_AVAIL=1
    ZLIB_CFLAGS="-I${BREW_PREFIX}/opt/zlib/include"
    ZLIB_LFLAGS="-L${BREW_PREFIX}/opt/zlib/lib"
  elif _check_header zlib.h; then
    ZLIB_AVAIL=1
  elif [[ -n "$BREW_PREFIX" && -d "${BREW_PREFIX}/opt/zlib" ]]; then
    ZLIB_AVAIL=1
    ZLIB_CFLAGS="-I${BREW_PREFIX}/opt/zlib/include"
    ZLIB_LFLAGS="-L${BREW_PREFIX}/opt/zlib/lib"
  fi

  # ── bzip2 (.bz2 support) ────────────────────────────────────────────────────
  if (( USE_BREW_LIBS )) && [[ -d "${BREW_PREFIX}/opt/bzip2" ]]; then
    BZ2_AVAIL=1
    BZ2_CFLAGS="-I${BREW_PREFIX}/opt/bzip2/include"
    BZ2_LFLAGS="-L${BREW_PREFIX}/opt/bzip2/lib"
  elif _check_header bzlib.h; then
    BZ2_AVAIL=1
  elif [[ -n "$BREW_PREFIX" && -d "${BREW_PREFIX}/opt/bzip2" ]]; then
    BZ2_AVAIL=1
    BZ2_CFLAGS="-I${BREW_PREFIX}/opt/bzip2/include"
    BZ2_LFLAGS="-L${BREW_PREFIX}/opt/bzip2/lib"
  fi

  # ── Nauty (graph automorphism, used by Cbc for symmetry detection) ────────
  # Cbc's configure auto-probes a "nauty" pkg-config module, so if we can
  # find one (system or Homebrew) no explicit flags are required. Otherwise
  # fall back to a plain header/lib check and pass explicit flags.
  if (( USE_BREW_LIBS )) && [[ -n "$BREW_PREFIX" ]] && _pkgcfg "${BREW_PREFIX}/lib/pkgconfig:${BREW_PREFIX}/opt/nauty/lib/pkgconfig" --exists nauty 2>/dev/null; then
    NAUTY_AVAIL=1
    NAUTY_CFLAGS="$(_pkgcfg "${BREW_PREFIX}/lib/pkgconfig:${BREW_PREFIX}/opt/nauty/lib/pkgconfig" --cflags nauty)"
    NAUTY_LFLAGS="$(_pkgcfg "${BREW_PREFIX}/lib/pkgconfig:${BREW_PREFIX}/opt/nauty/lib/pkgconfig" --libs nauty)"
  elif _pkgcfg "" --exists nauty 2>/dev/null; then
    NAUTY_AVAIL=1
  elif (( USE_BREW_LIBS )) && [[ -n "$BREW_PREFIX" && -d "${BREW_PREFIX}/opt/nauty" ]]; then
    NAUTY_AVAIL=1
    NAUTY_CFLAGS="-I${BREW_PREFIX}/opt/nauty/include"
    NAUTY_LFLAGS="-L${BREW_PREFIX}/opt/nauty/lib -lnauty"
  elif _check_header nauty/nauty.h; then
    NAUTY_AVAIL=1
    NAUTY_LFLAGS="-lnauty"
  elif [[ -n "$BREW_PREFIX" && -d "${BREW_PREFIX}/opt/nauty" ]]; then
    NAUTY_AVAIL=1
    NAUTY_CFLAGS="-I${BREW_PREFIX}/opt/nauty/include"
    NAUTY_LFLAGS="-L${BREW_PREFIX}/opt/nauty/lib -lnauty"
  fi

  # ── Resolve "unset" (-1) CLI/default state to the detected availability ───
  # A user-forced --lapack/--no-lapack (etc.) always wins; if never touched,
  # default to "on" when available, "off" when not found at all.
  [[ "$OPT_LAPACK" == "-1" ]] && OPT_LAPACK=$LAPACK_AVAIL
  [[ "$OPT_AMD"    == "-1" ]] && OPT_AMD=$AMD_AVAIL
  [[ "$OPT_ZLIB"   == "-1" ]] && OPT_ZLIB=$ZLIB_AVAIL
  [[ "$OPT_BZ2"    == "-1" ]] && OPT_BZ2=$BZ2_AVAIL
  [[ "$OPT_NAUTY"  == "-1" ]] && OPT_NAUTY=$NAUTY_AVAIL

  # A dependency explicitly requested on but not actually available cannot be
  # honoured — fall back to off with a warning rather than fail later deep
  # inside `configure`.
  if (( OPT_LAPACK && ! LAPACK_AVAIL )); then
    echo "${YELLOW}Warning: LAPACK/OpenBLAS not found — disabling.${RESET}" >&2
    OPT_LAPACK=0
  fi
  if (( OPT_AMD && ! AMD_AVAIL )); then
    echo "${YELLOW}Warning: SuiteSparse AMD not found — disabling.${RESET}" >&2
    OPT_AMD=0
  fi
  if (( OPT_ZLIB && ! ZLIB_AVAIL )); then
    echo "${YELLOW}Warning: zlib not found — disabling.${RESET}" >&2
    OPT_ZLIB=0
  fi
  if (( OPT_BZ2 && ! BZ2_AVAIL )); then
    echo "${YELLOW}Warning: bzip2 not found — disabling.${RESET}" >&2
    OPT_BZ2=0
  fi
  if (( OPT_NAUTY && ! NAUTY_AVAIL )); then
    echo "${YELLOW}Warning: Nauty not found — disabling.${RESET}" >&2
    OPT_NAUTY=0
  fi
}

# One-line human-readable summary of optional-dependency choices, e.g.
# "LAPACK:on zlib:on bz2:off" — omits deps that were never detected at all.
_deps_label() {
  local parts=()
  (( LAPACK_AVAIL )) && parts+=("LAPACK:$( (( OPT_LAPACK )) && echo on || echo off )")
  (( AMD_AVAIL ))    && parts+=("AMD:$( (( OPT_AMD ))    && echo on || echo off )")
  (( ZLIB_AVAIL ))   && parts+=("zlib:$( (( OPT_ZLIB ))   && echo on || echo off )")
  (( BZ2_AVAIL ))    && parts+=("bz2:$( (( OPT_BZ2 ))    && echo on || echo off )")
  (( NAUTY_AVAIL ))  && parts+=("nauty:$( (( OPT_NAUTY )) && echo on || echo off )")
  if [[ ${#parts[@]} -eq 0 ]]; then
    echo "none detected"
  else
    echo "${parts[*]}"
  fi
}

# Per-project extra configure options driven by optional-dependency choices.
# Populates the array named _EXTRA_OPTS (CoinUtils carries lapack/zlib/bz2;
# Clp carries AMD; Cbc carries Nauty — Osi/Cgl have no optional deps of
# their own).
_project_extra_opts() {
  local project="$1"
  _EXTRA_OPTS=()
  case "$project" in
    CoinUtils)
      if (( OPT_LAPACK )); then
        [[ -n "$LAPACK_LFLAGS" ]] && _EXTRA_OPTS+=("--with-lapack-lflags=${LAPACK_LFLAGS}")
      else
        _EXTRA_OPTS+=("--without-lapack")
      fi
      if (( ! OPT_ZLIB )); then
        _EXTRA_OPTS+=("--disable-zlib")
      fi
      if (( ! OPT_BZ2 )); then
        _EXTRA_OPTS+=("--disable-bzlib")
      fi
      ;;
    Clp)
      if (( OPT_AMD )); then
        [[ -n "$AMD_CFLAGS" ]] && _EXTRA_OPTS+=("--with-amd-cflags=${AMD_CFLAGS}")
        [[ -n "$AMD_LFLAGS" ]] && _EXTRA_OPTS+=("--with-amd-lflags=${AMD_LFLAGS}")
      else
        _EXTRA_OPTS+=("--without-amd")
      fi
      ;;
    Cbc)
      if (( OPT_NAUTY )); then
        [[ -n "$NAUTY_CFLAGS" ]] && _EXTRA_OPTS+=("--with-nauty-cflags=${NAUTY_CFLAGS}")
        [[ -n "$NAUTY_LFLAGS" ]] && _EXTRA_OPTS+=("--with-nauty-lflags=${NAUTY_LFLAGS}")
      else
        _EXTRA_OPTS+=("--without-nauty")
      fi
      ;;
  esac
}

# ── Compiler / flag assembly ─────────────────────────────────────────────────
FINAL_CXXFLAGS=""
FINAL_CFLAGS=""
FINAL_LDFLAGS=""

build_flags() {
  local cflags="" ldflags=""

  if [[ "$OPT_BUILD_MODE" == "opt" ]]; then
    cflags="-O3"
  else
    cflags="-O1 -g"
    case "$OPT_SANITIZER" in
      asan)
        cflags+=" -fsanitize=address -fno-omit-frame-pointer"
        ldflags+=" -fsanitize=address"
        ;;
      tsan)
        cflags+=" -fsanitize=thread -fno-omit-frame-pointer"
        ldflags+=" -fsanitize=thread"
        ;;
      valgrind)
        cflags+=" -fno-omit-frame-pointer"
        ;;
      none) : ;;
    esac
  fi

  case "$OPT_ARCH" in
    generic) : ;;
    native)  cflags+=" -march=native -mtune=native" ;;
    *)       cflags+=" -march=${OPT_ARCH} -mtune=${OPT_ARCH}" ;;
  esac

  # -ffp-contract=off is ALWAYS added, regardless of --arch, for reproducible
  # and stable floating-point results (no silent FMA contraction that could
  # change rounding behaviour between debug/opt or across CPU generations).
  cflags+=" -ffp-contract=off"

  if (( OPT_AVX2 )); then
    cflags+=" -DCOIN_AVX2=4"
  fi

  # Homebrew keg-only zlib/bzip2 need explicit -I/-L (only set when detection
  # had to fall back to a Homebrew opt/ path rather than the system default).
  if (( OPT_ZLIB )) && [[ -n "$ZLIB_CFLAGS" ]]; then
    cflags+=" $ZLIB_CFLAGS"
    ldflags+=" $ZLIB_LFLAGS"
  fi
  if (( OPT_BZ2 )) && [[ -n "$BZ2_CFLAGS" ]]; then
    cflags+=" $BZ2_CFLAGS"
    ldflags+=" $BZ2_LFLAGS"
  fi

  FINAL_CFLAGS="$cflags"
  FINAL_CXXFLAGS="$cflags"
  FINAL_LDFLAGS="$ldflags"
}

CONFIGURE_OPTS=()

build_configure_opts() {
  CONFIGURE_OPTS=()
  case "$OPT_LIB_TYPE" in
    static) CONFIGURE_OPTS+=("--enable-static" "--disable-shared") ;;
    shared) CONFIGURE_OPTS+=("--disable-static" "--enable-shared") ;;
    both)   CONFIGURE_OPTS+=("--enable-static"  "--enable-shared") ;;
  esac
}

# ══════════════════════════════════════════════════════════════════════════════
#  TUI  (dialog-based)
# ══════════════════════════════════════════════════════════════════════════════

DIALOG_BIN=""

_find_dialog() {
  if   command -v dialog   &>/dev/null; then DIALOG_BIN="dialog"
  elif command -v whiptail &>/dev/null; then DIALOG_BIN="whiptail"
  else
    echo "${YELLOW}Warning: neither 'dialog' nor 'whiptail' found; " \
         "falling back to plain prompts.${RESET}" >&2
    DIALOG_BIN="plain"
  fi
}

# Wrapper: captures dialog selection into $REPLY; returns dialog exit code.
_dlg() {
  REPLY=$("$DIALOG_BIN" "$@" 2>&1 >/dev/tty)
}

# Strip surrounding double-quotes that dialog sometimes emits
_strip_quotes() { echo "${1//\"/}"; }

run_tui() {
  _find_dialog

  if [[ "$DIALOG_BIN" == "plain" ]]; then
    run_tui_plain
    return
  fi

  local BT="  ◆  cbc-workspace  ─  Build Configurator  ◆"

  # ── 1. Build mode ────────────────────────────────────────────────────────
  _dlg --backtitle "$BT" \
       --title "  Build Mode  " \
       --radiolist $'\nSelect the build mode:\n' 11 54 2 \
       "opt"   "Optimised  (-O3, release build)"   ON  \
       "debug" "Debug  (-O1 -g, enable assertions)" OFF \
    || { echo "${YELLOW}Cancelled.${RESET}"; exit 0; }
  OPT_BUILD_MODE="$(_strip_quotes "$REPLY")"

  # ── 2. Sanitiser (debug only) ────────────────────────────────────────────
  if [[ "$OPT_BUILD_MODE" == "debug" ]]; then
    _dlg --backtitle "$BT" \
         --title "  Runtime Sanitiser  " \
         --radiolist $'\nSelect runtime instrumentation:\n' 12 62 3 \
         "none"     "None  (plain debug build)"               ON  \
         "asan"     "AddressSanitizer  (memory errors)"       OFF \
         "tsan"     "ThreadSanitizer  (data races)"           OFF \
         "valgrind" "Valgrind-friendly  (no sanitiser, full frames)" OFF \
      || { echo "${YELLOW}Cancelled.${RESET}"; exit 0; }
    OPT_SANITIZER="$(_strip_quotes "$REPLY")"
  fi

  # ── 3. Target architecture (single choice) ────────────────────────────────
  local arch_args=("native" "$(_arch_label native)" ON \
                    "generic" "$(_arch_label generic)" OFF)
  local preset
  for preset in $(_arch_choices); do
    arch_args+=("$preset" "$(_arch_label "$preset")" OFF)
  done
  local n_arch=$(( ${#arch_args[@]} / 3 ))
  local arch_h=$(( n_arch + 8 ))

  _dlg --backtitle "$BT" \
       --title "  Target Architecture  " \
       --radiolist $'\nSelect the CPU generation to compile for (always adds -ffp-contract=off):\n' \
       "$arch_h" 74 "$n_arch" "${arch_args[@]}" \
    || { echo "${YELLOW}Cancelled.${RESET}"; exit 0; }
  OPT_ARCH="$(_strip_quotes "$REPLY")"

  # ── 4. AVX2 hand-written SIMD (x86_64 only) ───────────────────────────────
  OPT_AVX2=0
  if [[ "$ARCH" == "x86_64" ]]; then
    if "$DIALOG_BIN" --backtitle "$BT" \
         --title "  AVX2 hand-written SIMD  " \
         --yesno $'\nEnable -DCOIN_AVX2=4 (hand-written SIMD in ClpSimplexDual)?\n' 8 66 \
         2>/dev/null >/dev/tty; then
      OPT_AVX2=1
    fi
  fi

  # ── 5. Optional dependencies (checklist; only detected ones are shown) ────
  local dep_items=()
  (( LAPACK_AVAIL )) && dep_items+=("lapack" "LAPACK/BLAS  (${LAPACK_WHAT:-detected}; dense factorisations)" \
                                     "$( (( OPT_LAPACK )) && echo on || echo off )")
  (( AMD_AVAIL ))    && dep_items+=("amd"    "SuiteSparse AMD  (ordering for Clp Cholesky)" \
                                     "$( (( OPT_AMD ))    && echo on || echo off )")
  (( ZLIB_AVAIL ))   && dep_items+=("zlib"   "zlib   (.gz compressed MPS/LP file I/O)" \
                                     "$( (( OPT_ZLIB ))   && echo on || echo off )")
  (( BZ2_AVAIL ))    && dep_items+=("bz2"    "bzip2  (.bz2 compressed MPS/LP file I/O)" \
                                     "$( (( OPT_BZ2 ))    && echo on || echo off )")
  (( NAUTY_AVAIL ))  && dep_items+=("nauty"  "Nauty  (graph automorphism; Cbc symmetry cuts)" \
                                     "$( (( OPT_NAUTY ))  && echo on || echo off )")

  if [[ ${#dep_items[@]} -gt 0 ]]; then
    local n_deps=$(( ${#dep_items[@]} / 3 ))
    local dep_h=$(( n_deps + 8 ))
    _dlg --backtitle "$BT" \
         --title "  Optional Dependencies  " \
         --checklist $'\nToggle detected optional libraries (Space = toggle, Enter = confirm):\n' \
         "$dep_h" 72 "$n_deps" "${dep_items[@]}" \
      || { echo "${YELLOW}Cancelled.${RESET}"; exit 0; }
    local dep_selected="$(_strip_quotes "$REPLY")"

    (( LAPACK_AVAIL )) && OPT_LAPACK=0
    (( AMD_AVAIL ))    && OPT_AMD=0
    (( ZLIB_AVAIL ))   && OPT_ZLIB=0
    (( BZ2_AVAIL ))    && OPT_BZ2=0
    (( NAUTY_AVAIL ))  && OPT_NAUTY=0
    local tok
    for tok in $dep_selected; do
      case "$tok" in
        lapack) OPT_LAPACK=1 ;;
        amd)    OPT_AMD=1    ;;
        zlib)   OPT_ZLIB=1   ;;
        bz2)    OPT_BZ2=1    ;;
        nauty)  OPT_NAUTY=1  ;;
      esac
    done
  fi

  # ── 6. Library type ───────────────────────────────────────────────────────
  _dlg --backtitle "$BT" \
       --title "  Library Type  " \
       --radiolist $'\nSelect which library types to build:\n' 12 60 3 \
       "static" "Static only   (--enable-static --disable-shared)"  ON  \
       "shared" "Shared only   (--enable-shared --disable-static)"   OFF \
       "both"   "Both static and shared"                              OFF \
    || { echo "${YELLOW}Cancelled.${RESET}"; exit 0; }
  OPT_LIB_TYPE="$(_strip_quotes "$REPLY")"

  # ── 7. Install prefix ─────────────────────────────────────────────────────
  derive_prefix   # populate default before asking
  _dlg --backtitle "$BT" \
       --title "  Install Prefix  " \
       --inputbox $'\nInstallation prefix (shared by all 5 projects):\n' 9 64 "$OPT_PREFIX" \
    || { echo "${YELLOW}Cancelled.${RESET}"; exit 0; }
  OPT_PREFIX="${REPLY/#\~/$HOME}"

  # ── 8. Parallel jobs ──────────────────────────────────────────────────────
  _dlg --backtitle "$BT" \
       --title "  Parallel Jobs  " \
       --inputbox $'\nNumber of parallel make jobs (per project):\n' 9 40 "$OPT_JOBS" \
    || { echo "${YELLOW}Cancelled.${RESET}"; exit 0; }
  OPT_JOBS="$REPLY"

  # ── 9. Post-configure actions ─────────────────────────────────────────────
  if "$DIALOG_BIN" --backtitle "$BT" \
       --title "  Post-Configure  " \
       --yesno $'\nRun build automatically after configure?\n' 8 54 \
       2>/dev/null >/dev/tty; then
    OPT_DO_BUILD=1
    if "$DIALOG_BIN" --backtitle "$BT" \
         --title "  Post-Build  " \
         --yesno $'\nRun install automatically after build?\n' 8 54 \
         2>/dev/null >/dev/tty; then
      OPT_DO_INSTALL=1
    fi
  fi

  # ── Summary ───────────────────────────────────────────────────────────────
  local san_lbl="$OPT_SANITIZER"
  [[ "$OPT_BUILD_MODE" == "opt" && "$OPT_SANITIZER" == "none" ]] && san_lbl="n/a"
  local avx2_lbl="n/a (aarch64)"
  [[ "$ARCH" == "x86_64" ]] && avx2_lbl="$( (( OPT_AVX2 )) && echo yes || echo no )"

  local summary
  summary=$(printf "%-18s %s\n" \
    "Projects:"      "${PROJECTS[*]}" \
    "Build mode:"    "$OPT_BUILD_MODE" \
    "Sanitiser:"     "$san_lbl" \
    "Target arch:"   "$OPT_ARCH" \
    "AVX2 (SIMD):"   "$avx2_lbl" \
    "Opt. deps:"     "$(_deps_label)" \
    "Library type:"  "$OPT_LIB_TYPE" \
    "Install prefix:" "$OPT_PREFIX" \
    "Jobs:"          "$OPT_JOBS" \
    "Build after:"   "$( (( OPT_DO_BUILD   )) && echo yes || echo no )" \
    "Install after:" "$( (( OPT_DO_INSTALL )) && echo yes || echo no )")

  "$DIALOG_BIN" --backtitle "$BT" \
    --title "  Configuration Summary  " \
    --yesno "$(printf '\n%s\n\nProceed?' "$summary")" 20 66 \
    2>/dev/null >/dev/tty \
    || { echo "${YELLOW}Aborted by user.${RESET}"; exit 0; }
}

# ── Plain interactive fallback (no dialog) ────────────────────────────────────
run_tui_plain() {
  local yn
  echo ""
  echo "${BOLD}${CYAN}── cbc-workspace Build Configurator ─────────────────────────${RESET}"
  echo ""
  echo "  Projects (in order): ${PROJECTS[*]}"
  echo ""

  read -rp "  Build mode [opt/debug] (default: opt): " yn
  [[ -n "$yn" ]] && OPT_BUILD_MODE="$yn"

  if [[ "$OPT_BUILD_MODE" == "debug" ]]; then
    read -rp "  Sanitiser [none/asan/tsan/valgrind] (default: none): " yn
    [[ -n "$yn" ]] && OPT_SANITIZER="$yn"
  fi

  read -rp "  Target arch [native/generic/$(_arch_choices | tr ' ' '/')] (default: native): " yn
  [[ -n "$yn" ]] && OPT_ARCH="$yn"

  if [[ "$ARCH" == "x86_64" ]]; then
    read -rp "  Enable -DCOIN_AVX2=4 hand-written SIMD? [y/N]: " yn
    [[ "$yn" == [Yy]* ]] && OPT_AVX2=1
  fi

  if (( LAPACK_AVAIL )); then
    read -rp "  Use LAPACK/BLAS (${LAPACK_WHAT:-detected})? [Y/n]: " yn
    [[ "$yn" == [Nn]* ]] && OPT_LAPACK=0 || OPT_LAPACK=1
  fi
  if (( AMD_AVAIL )); then
    read -rp "  Enable SuiteSparse AMD ordering (Clp Cholesky)? [Y/n]: " yn
    [[ "$yn" == [Nn]* ]] && OPT_AMD=0 || OPT_AMD=1
  fi
  if (( ZLIB_AVAIL )); then
    read -rp "  Enable zlib (.gz compressed file I/O)? [Y/n]: " yn
    [[ "$yn" == [Nn]* ]] && OPT_ZLIB=0 || OPT_ZLIB=1
  fi
  if (( BZ2_AVAIL )); then
    read -rp "  Enable bzip2 (.bz2 compressed file I/O)? [Y/n]: " yn
    [[ "$yn" == [Nn]* ]] && OPT_BZ2=0 || OPT_BZ2=1
  fi
  if (( NAUTY_AVAIL )); then
    read -rp "  Enable Nauty (graph automorphism, Cbc symmetry cuts)? [Y/n]: " yn
    [[ "$yn" == [Nn]* ]] && OPT_NAUTY=0 || OPT_NAUTY=1
  fi

  read -rp "  Library type [static/shared/both] (default: static): " yn
  [[ -n "$yn" ]] && OPT_LIB_TYPE="$yn"

  derive_prefix
  read -rp "  Install prefix (default: $OPT_PREFIX): " yn
  [[ -n "$yn" ]] && OPT_PREFIX="${yn/#\~/$HOME}"

  read -rp "  Parallel jobs (default: $OPT_JOBS): " yn
  [[ -n "$yn" ]] && OPT_JOBS="$yn"

  read -rp "  Run build after configure? [y/N]: " yn
  [[ "$yn" == [Yy]* ]] && OPT_DO_BUILD=1

  if (( OPT_DO_BUILD )); then
    read -rp "  Run install after build? [y/N]: " yn
    [[ "$yn" == [Yy]* ]] && OPT_DO_INSTALL=1
  fi
}

# ══════════════════════════════════════════════════════════════════════════════
#  Progress & output helpers
# ══════════════════════════════════════════════════════════════════════════════

_banner() {
  echo ""
  echo "${BOLD}${CYAN}╔══════════════════════════════════════════════════════════════╗${RESET}"
  echo "${BOLD}${CYAN}║       cbc-workspace  ─  Unified Build Configurator            ║${RESET}"
  echo "${BOLD}${CYAN}╚══════════════════════════════════════════════════════════════╝${RESET}"
}

_section() {
  echo ""
  echo "${BOLD}${BLUE}┌─ $1${RESET}"
}

_STEP=0; _TOTAL=0

_step() {
  local project="$1" action="$2"
  _STEP=$(( _STEP + 1 ))
  printf "${BOLD}${YELLOW}  [%d/%d] %s: ${MAGENTA}%s${RESET}\n" \
    "$_STEP" "$_TOTAL" "$action" "$project"
}

_ok()   { echo "${GREEN}        ✓  done${RESET}"; }
_fail() { echo "${RED}        ✗  FAILED${RESET}"; }

_print_cmdline() {
  local args=()

  args+=("--${OPT_BUILD_MODE}")

  if [[ "$OPT_BUILD_MODE" == "debug" && "$OPT_SANITIZER" != "none" ]]; then
    args+=("--sanitizer=${OPT_SANITIZER}")
  fi

  args+=("--arch=${OPT_ARCH}")
  [[ "$ARCH" == "x86_64" ]] && { (( OPT_AVX2 )) && args+=("--avx2") || args+=("--no-avx2"); }

  (( LAPACK_AVAIL )) && { (( OPT_LAPACK )) && args+=("--lapack") || args+=("--no-lapack"); }
  (( AMD_AVAIL ))    && { (( OPT_AMD )) && args+=("--amd") || args+=("--no-amd"); }
  (( ZLIB_AVAIL ))   && { (( OPT_ZLIB )) && args+=("--zlib") || args+=("--no-zlib"); }
  (( BZ2_AVAIL ))    && { (( OPT_BZ2 )) && args+=("--bz2") || args+=("--no-bz2"); }
  (( NAUTY_AVAIL ))  && { (( OPT_NAUTY )) && args+=("--nauty") || args+=("--no-nauty"); }

  args+=("--${OPT_LIB_TYPE}")
  args+=("--prefix=${OPT_PREFIX}")
  args+=("--jobs=${OPT_JOBS}")

  if (( OPT_DO_INSTALL )); then
    args+=("--install")
  elif (( OPT_DO_BUILD )); then
    args+=("--build")
  fi
  (( OPT_DRY_RUN )) && args+=("--dry-run")

  _section "Equivalent command line"
  local i last=$(( ${#args[@]} - 1 ))
  printf "  ${DIM}./$SCRIPT_NAME"
  for (( i=0; i<${#args[@]}; i++ )); do
    if (( i == 0 )); then
      printf " ${CYAN}%s${RESET}" "${args[$i]}"
    else
      printf " \\\\\n    ${CYAN}%s${RESET}" "${args[$i]}"
    fi
  done
  echo ""
  echo ""
}

_print_summary() {
  local san_lbl="$OPT_SANITIZER"
  [[ "$OPT_BUILD_MODE" == "opt" && "$OPT_SANITIZER" == "none" ]] && san_lbl="n/a"
  local avx2_lbl="n/a (aarch64)"
  [[ "$ARCH" == "x86_64" ]] && avx2_lbl="$( (( OPT_AVX2 )) && echo on || echo off )"

  _section "Configuration"
  printf "  ${BOLD}%-22s${RESET}${CYAN}%s${RESET}\n" \
    "Host arch:"       "$ARCH" \
    "Projects:"        "${PROJECTS[*]}" \
    "Build mode:"      "$OPT_BUILD_MODE" \
    "Sanitiser:"       "$san_lbl" \
    "Target arch:"     "$OPT_ARCH" \
    "AVX2 (SIMD):"     "$avx2_lbl" \
    "Opt. deps:"       "$(_deps_label)" \
    "Library type:"    "$OPT_LIB_TYPE" \
    "Install prefix:"  "$OPT_PREFIX" \
    "Parallel jobs:"   "$OPT_JOBS" \
    "Build after:"     "$( (( OPT_DO_BUILD   )) && echo yes || echo no )" \
    "Install after:"   "$( (( OPT_DO_INSTALL )) && echo yes || echo no )"
  echo ""
  printf "  ${BOLD}%-22s${RESET}${DIM}%s${RESET}\n" \
    "ADD_CXXFLAGS:" "$FINAL_CXXFLAGS" \
    "LDFLAGS:"      "${FINAL_LDFLAGS:-(none)}"
  echo ""
  _print_cmdline
}

# ══════════════════════════════════════════════════════════════════════════════
#  Configure / build / install workers
# ══════════════════════════════════════════════════════════════════════════════

_colorize_make() {
  while IFS= read -r line; do
    if [[ "$line" == *": error:"* || "$line" == *": fatal error:"* ]]; then
      echo "    ${RED}${line}${RESET}"
    elif [[ "$line" == *": warning:"* ]]; then
      echo "    ${YELLOW}${line}${RESET}"
    else
      echo "    ${DIM}${line}${RESET}"
    fi
  done
}

_build_one() {
  local project="$1"
  printf "        ${DIM}▸ building ...${RESET}"
  if (( OPT_DRY_RUN )); then
    echo "  ${DIM}[dry-run]${RESET}"; return
  fi
  # Always clean before building in the interleaved mode. Autotools does not
  # invalidate stale .la files when the prefix or CXXFLAGS change, so a
  # previous opt build's libFoo.la dependency_libs (pointing to the old
  # prefix) will silently pollute a fresh debug/asan build.
  local dir
  dir="$(_project_dir "$project")"
  make -C "$dir" clean -j"${OPT_JOBS}" >/dev/null 2>&1 || true
  local rc=0
  local tmplog
  tmplog="$(mktemp)"
  make -C "$dir" -j"${OPT_JOBS}" >"$tmplog" 2>&1 || rc=$?
  if (( rc )); then
    echo ""
    echo "${RED}        ✗  build failed (exit ${rc})${RESET}"
    echo ""
    echo "${RED}  ── Build output ──────────────────────────────────────────────${RESET}"
    _colorize_make < "$tmplog"
    echo "${RED}  ──────────────────────────────────────────────────────────────${RESET}"
    rm -f "$tmplog"
    echo "${RED}  ✗ Build failed for ${project}.${RESET}" >&2
    exit "$rc"
  fi
  rm -f "$tmplog"
  echo "  ${GREEN}✓${RESET}"
}

_install_one() {
  local project="$1"
  printf "        ${DIM}▸ installing ...${RESET}"
  if (( OPT_DRY_RUN )); then
    echo "  ${DIM}[dry-run]${RESET}"; return
  fi
  local dir
  dir="$(_project_dir "$project")"
  local rc=0
  local tmplog
  tmplog="$(mktemp)"
  make -C "$dir" install -j"${OPT_JOBS}" >"$tmplog" 2>&1 || rc=$?
  if (( rc )); then
    echo ""
    echo "${RED}        ✗  install failed (exit ${rc})${RESET}"
    echo ""
    echo "${RED}  ── Install output ─────────────────────────────────────────────${RESET}"
    _colorize_make < "$tmplog"
    echo "${RED}  ──────────────────────────────────────────────────────────────${RESET}"
    rm -f "$tmplog"
    echo "${RED}  ✗ Install failed for ${project}.${RESET}" >&2
    exit "$rc"
  fi
  rm -f "$tmplog"
  echo "  ${GREEN}✓${RESET}"
}

run_configure() {
  export PKG_CONFIG_PATH="${OPT_PREFIX}/lib/pkgconfig:${OPT_PREFIX}/lib64/pkgconfig:${PKG_CONFIG_PATH:-}"
  mkdir -p "$OPT_PREFIX"

  _STEP=0
  _TOTAL=${#PROJECTS[@]}

  # When building or installing, each project must be installed before the next
  # can be configured (Cgl needs Clp's .pc file in PREFIX, Cbc needs all 4, etc.).
  # Use interleaved mode: configure → build → install per project.
  if (( OPT_DO_BUILD || OPT_DO_INSTALL )); then
    local mode_lbl="configure"
    (( OPT_DO_BUILD   )) && mode_lbl+=" + build"
    (( OPT_DO_INSTALL )) && mode_lbl+=" + install"
    _section "${mode_lbl}  (prefix: ${CYAN}${OPT_PREFIX}${RESET}${BLUE}, jobs: ${CYAN}${OPT_JOBS}${RESET}${BLUE})"

    local _START=$SECONDS
    for project in "${PROJECTS[@]}"; do
      local dir
      dir="$(_project_dir "$project")"
      if [[ ! -d "$dir" ]]; then
        echo "${YELLOW}  warning: $dir not found (submodule not initialized?) — skipping${RESET}" >&2
        continue
      fi

      _step "$project" "Configure+Build+Install"
      printf "        ${DIM}▸ configuring ...${RESET}"

      local _EXTRA_OPTS
      _project_extra_opts "$project"

      if (( OPT_DRY_RUN )); then
        echo "  ${DIM}[dry-run]${RESET}"
      else
        local rc=0
        local tmplog
        tmplog="$(mktemp)"
        (
          cd "$dir"
          ADD_CXXFLAGS="$FINAL_CXXFLAGS" CFLAGS="$FINAL_CFLAGS" LDFLAGS="$FINAL_LDFLAGS" \
            ./configure --prefix="$OPT_PREFIX" "${CONFIGURE_OPTS[@]}" ${_EXTRA_OPTS[@]+"${_EXTRA_OPTS[@]}"}
        ) >"$tmplog" 2>&1 || rc=$?
        if (( rc )); then
          echo ""
          _fail
          echo ""
          echo "${RED}  ── Configure output ───────────────────────────────────────────${RESET}"
          while IFS= read -r line; do echo "    ${DIM}${line}${RESET}"; done < "$tmplog"
          echo "${RED}  ──────────────────────────────────────────────────────────────${RESET}"
          rm -f "$tmplog"
          echo "${RED}  ✗ configure failed for ${project} (exit ${rc}).${RESET}" >&2
          exit "$rc"
        fi
        rm -f "$tmplog"
        echo "  ${GREEN}✓${RESET}"
      fi

      (( OPT_DO_BUILD   )) && _build_one   "$project"
      (( OPT_DO_INSTALL )) && _install_one "$project"
      echo ""
    done

    local elapsed=$(( SECONDS - _START ))
    printf "${BOLD}${GREEN}  ✓  All projects configured"
    (( OPT_DO_BUILD   )) && printf ", built"
    (( OPT_DO_INSTALL )) && printf ", installed"
    printf ".  Elapsed: %dm%02ds${RESET}\n" $(( elapsed / 60 )) $(( elapsed % 60 ))
    return
  fi

  # Configure-only mode (prefix must already contain .pc files from a prior install).
  _section "Configuring  (prefix: ${CYAN}${OPT_PREFIX}${RESET}${BLUE})"
  echo "  ${YELLOW}Note: prefix must already contain installed .pc files from a prior build.${RESET}"
  echo "  ${YELLOW}      If starting fresh, use --build/--install to interleave configure+build+install.${RESET}"
  echo ""

  for project in "${PROJECTS[@]}"; do
    local dir
    dir="$(_project_dir "$project")"
    if [[ ! -d "$dir" ]]; then
      echo "${YELLOW}  warning: $dir not found (submodule not initialized?) — skipping${RESET}" >&2
      continue
    fi
    _step "$project" "Configuring"
    local _EXTRA_OPTS
    _project_extra_opts "$project"
    if (( OPT_DRY_RUN )); then
      echo "    ${DIM}[dry-run] ADD_CXXFLAGS='${FINAL_CXXFLAGS}' LDFLAGS='${FINAL_LDFLAGS}' \\"
      echo "              ./configure --prefix=${OPT_PREFIX} ${CONFIGURE_OPTS[*]} ${_EXTRA_OPTS[*]+${_EXTRA_OPTS[*]}}${RESET}"
      _ok; continue
    fi
    local rc=0
    (
      cd "$dir"
      ADD_CXXFLAGS="$FINAL_CXXFLAGS" CFLAGS="$FINAL_CFLAGS" LDFLAGS="$FINAL_LDFLAGS" \
        ./configure --prefix="$OPT_PREFIX" "${CONFIGURE_OPTS[@]}" ${_EXTRA_OPTS[@]+"${_EXTRA_OPTS[@]}"}
    ) || rc=$?
    if (( rc )); then
      _fail
      echo "${RED}  ✗ configure failed for ${project} (exit ${rc}).${RESET}" >&2
      exit "$rc"
    fi
    _ok
  done

  echo ""
  echo "${BOLD}${GREEN}  ✓  All projects configured.${RESET}"
}

# ══════════════════════════════════════════════════════════════════════════════
#  Main
# ══════════════════════════════════════════════════════════════════════════════
main() {
  parse_args "$@"

  validate_opts
  derive_prefix
  detect_optional_deps

  # Launch TUI when: no args given at all, or --interactive was passed
  if (( ! _ARGS_GIVEN )) || (( OPT_INTERACTIVE )); then
    run_tui
    printf '\n\n'   # ensure output starts below TUI dialog residue
  fi

  build_flags
  build_configure_opts

  _banner
  _print_summary

  [[ "$OPT_DRY_RUN" == "1" ]] && echo "${YELLOW}  ── DRY RUN: no commands will be executed ──${RESET}"

  run_configure

  echo ""
  echo "${BOLD}${GREEN}╔════════════════════════════════════╗${RESET}"
  echo "${BOLD}${GREEN}║  All done!                         ║${RESET}"
  echo "${BOLD}${GREEN}╚════════════════════════════════════╝${RESET}"
  echo ""
}

main "$@"
