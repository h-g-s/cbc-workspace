#!/usr/bin/env bash
# ══════════════════════════════════════════════════════════════════════════════
#  package  ─  Turn a `config --install`-ed prefix into a self-contained,
#              relocatable distribution bundle (bin/ + lib/ + include/ + share/).
#
#  Copies the installed tree, then for every ELF/Mach-O/PE binary and shared
#  library bundles any non-system runtime dependency alongside it and rewrites
#  its rpath/RUNPATH (Linux: patchelf) or install name / rpath (macOS:
#  install_name_tool) so the result runs on a bare target machine without
#  needing the build system's dev packages installed — this is what makes the
#  manylinux-style / cross-distro binaries in CI actually portable.
#
#  On Windows (MSYS2/MinGW) DLL dependencies are simply copied next to the
#  .exe — Windows has no rpath concept, it searches the executable's own
#  directory first.
#
#  Usage:
#    ./package --prefix=PATH --name=NAME [--out=DIR] [--dry-run]
#
#  Options:
#    --prefix=PATH   Installed prefix to package (as produced by `./config
#                     --install --prefix=PATH`).                 [required]
#    --name=NAME     Distribution name; output is <out>/<name>.tar.gz
#                     (or .zip on Windows).                       [required]
#    --out=DIR       Output directory for the archive.        [default: dist]
#    --dry-run       Print what would be done, don't touch anything.
#    --help, -h      Show this help.
# ══════════════════════════════════════════════════════════════════════════════
set -euo pipefail

SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

OPT_PREFIX=""
OPT_NAME=""
OPT_OUT="dist"
DRY_RUN=0

for arg in "$@"; do
  case "$arg" in
    --prefix=*)  OPT_PREFIX="${arg#--prefix=}" ;;
    --name=*)    OPT_NAME="${arg#--name=}" ;;
    --out=*)     OPT_OUT="${arg#--out=}" ;;
    --dry-run)   DRY_RUN=1 ;;
    -h|--help)
      sed -n '2,26p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
      exit 0 ;;
    *)
      echo "unknown option: $arg" >&2; exit 1 ;;
  esac
done

[[ -z "$OPT_PREFIX" ]] && { echo "error: --prefix=PATH is required" >&2; exit 1; }
[[ -z "$OPT_NAME"   ]] && { echo "error: --name=NAME is required"   >&2; exit 1; }
[[ -d "$OPT_PREFIX" ]] || { echo "error: prefix not found: $OPT_PREFIX" >&2; exit 1; }

OPT_PREFIX="$(cd "$OPT_PREFIX" && pwd)"

# ── OS detection ────────────────────────────────────────────────────────────
KERNEL="$(uname -s)"
case "$KERNEL" in
  Linux)            OS_KIND="linux" ;;
  Darwin)           OS_KIND="macos" ;;
  MINGW*|MSYS*|CYGWIN*) OS_KIND="windows" ;;
  *) echo "error: unsupported OS: $KERNEL" >&2; exit 1 ;;
esac

STAGE_DIR="$(mktemp -d)"
DIST_ROOT="$STAGE_DIR/$OPT_NAME"

_run() {
  if [[ $DRY_RUN -eq 1 ]]; then
    echo "+ $*"
  else
    "$@"
  fi
}

echo "==> Packaging '$OPT_PREFIX' as '$OPT_NAME' (OS: $OS_KIND)"

# ── Baseline system libs that must NOT be bundled (always assumed present on
#    the target machine) ─────────────────────────────────────────────────────
is_baseline_lib() {
  local soname
  soname="$(basename "$1")"
  case "$soname" in
    linux-vdso.so*|ld-linux*.so*|libc.so*|libm.so*|libpthread.so*|libdl.so*|librt.so*|\
    libresolv.so*|libutil.so*)
      return 0 ;;
    *) return 1 ;;
  esac
}

# ── 1. Copy the installed tree (skip static libs/.la/.pc — dev-only) ────────
mkdir -p "$DIST_ROOT"
_run mkdir -p "$DIST_ROOT"
if [[ $DRY_RUN -eq 0 ]]; then
  rsync -a --exclude='*.la' --exclude='pkgconfig/' "$OPT_PREFIX"/ "$DIST_ROOT"/
fi

# ── 2. Collect the set of binaries/libs to fix up ───────────────────────────
mapfile -t BIN_FILES < <(find "$DIST_ROOT/bin" -maxdepth 1 -type f 2>/dev/null || true)
mapfile -t LIB_FILES < <(find "$DIST_ROOT/lib" -maxdepth 1 -type f \( -name '*.so*' -o -name '*.dylib' \) 2>/dev/null || true)

if [[ $DRY_RUN -eq 1 ]]; then
  echo "+ would bundle deps for: ${BIN_FILES[*]:-<none>} ${LIB_FILES[*]:-<none>}"
  echo "+ would archive $DIST_ROOT -> $OPT_OUT/$OPT_NAME.tar.gz"
  exit 0
fi

mkdir -p "$DIST_ROOT/lib"

# ── 3a. Linux: ldd + patchelf ────────────────────────────────────────────────
bundle_linux() {
  command -v patchelf &>/dev/null || { echo "error: patchelf is required on Linux" >&2; exit 1; }

  # Fixed-point loop: bundling a dep can introduce new transitive deps.
  local changed=1 f soname sopath dest rel
  while [[ $changed -eq 1 ]]; do
    changed=0
    for f in "${BIN_FILES[@]}" "$DIST_ROOT"/lib/*.so* ; do
      [[ -f "$f" && ! -L "$f" ]] || continue
      file "$f" 2>/dev/null | grep -q ELF || continue
      while read -r soname sopath; do
        [[ -z "$soname" ]] && continue
        is_baseline_lib "$soname" && continue
        [[ -f "$DIST_ROOT/lib/$soname" ]] && continue
        [[ -n "$sopath" && -f "$sopath" ]] || continue
        cp -L "$sopath" "$DIST_ROOT/lib/$soname"
        echo "    bundled: $soname"
        changed=1
      done < <(ldd "$f" 2>/dev/null | awk '/=>/{print $1, $3}')
    done
  done

  for f in "${BIN_FILES[@]}"; do
    [[ -f "$f" ]] || continue
    file "$f" | grep -q ELF || continue
    patchelf --set-rpath '$ORIGIN/../lib' "$f"
  done
  find "$DIST_ROOT/lib" -maxdepth 1 -name '*.so*' ! -type l | while read -r f; do
    file "$f" | grep -q ELF && patchelf --set-rpath '$ORIGIN' "$f"
  done

  # Sanity check: no remaining non-system, non-bundled deps.
  local warned=0
  for f in "${BIN_FILES[@]}"; do
    [[ -f "$f" ]] || continue
    while read -r soname sopath; do
      [[ -z "$soname" ]] && continue
      is_baseline_lib "$soname" && continue
      [[ -f "$DIST_ROOT/lib/$soname" ]] && continue
      echo "    WARNING: $f still depends on unbundled $soname ($sopath)" >&2
      warned=1
    done < <(ldd "$f" 2>/dev/null | awk '/=>/{print $1, $3}')
  done
  [[ $warned -eq 1 ]] && echo "    (see warnings above — binary may not be portable)" >&2 || true
}

# ── 3b. macOS: otool + install_name_tool ─────────────────────────────────────
bundle_macos() {
  command -v install_name_tool &>/dev/null || { echo "error: install_name_tool required" >&2; exit 1; }

  is_macos_baseline() {
    case "$1" in
      /usr/lib/*|/System/Library/*) return 0 ;;
      *) return 1 ;;
    esac
  }

  local changed=1 f dep dest base
  while [[ $changed -eq 1 ]]; do
    changed=0
    for f in "${BIN_FILES[@]}" "$DIST_ROOT"/lib/*.dylib; do
      [[ -f "$f" ]] || continue
      file "$f" 2>/dev/null | grep -q "Mach-O" || continue
      while read -r dep; do
        [[ -z "$dep" ]] && continue
        is_macos_baseline "$dep" && continue
        [[ "$dep" == @rpath/* || "$dep" == @loader_path/* || "$dep" == @executable_path/* ]] && continue
        base="$(basename "$dep")"
        dest="$DIST_ROOT/lib/$base"
        if [[ ! -f "$dest" && -f "$dep" ]]; then
          cp -L "$dep" "$dest"
          chmod +w "$dest"
          echo "    bundled: $base"
          changed=1
        fi
        [[ -f "$dest" ]] && install_name_tool -change "$dep" "@rpath/$base" "$f" 2>/dev/null || true
      done < <(otool -L "$f" | tail -n +2 | awk '{print $1}')
    done
  done

  for f in "${BIN_FILES[@]}"; do
    [[ -f "$f" ]] || continue
    file "$f" | grep -q "Mach-O" || continue
    install_name_tool -add_rpath "@executable_path/../lib" "$f" 2>/dev/null || true
  done
  find "$DIST_ROOT/lib" -maxdepth 1 -name '*.dylib' | while read -r f; do
    install_name_tool -add_rpath "@loader_path" "$f" 2>/dev/null || true
  done
}

# ── 3c. Windows (MSYS2/MinGW): ldd + plain copy (no rpath concept) ──────────
bundle_windows() {
  is_win_baseline() {
    case "$1" in
      /c/Windows/*|/mingw64/bin/msys-*.dll) return 0 ;;
      *) return 1 ;;
    esac
  }
  local changed=1 f soname sopath
  while [[ $changed -eq 1 ]]; do
    changed=0
    for f in "${BIN_FILES[@]}"; do
      [[ -f "$f" ]] || continue
      while read -r soname sopath; do
        [[ -z "$soname" ]] && continue
        is_win_baseline "$sopath" && continue
        [[ -f "$DIST_ROOT/bin/$soname" ]] && continue
        [[ -n "$sopath" && -f "$sopath" ]] || continue
        cp -L "$sopath" "$DIST_ROOT/bin/$soname"
        echo "    bundled: $soname"
        changed=1
      done < <(ldd "$f" 2>/dev/null | awk '/=>/{print $1, $3}')
    done
    # DLLs we just copied may themselves have further deps — re-scan them too.
    BIN_FILES+=("$DIST_ROOT"/bin/*.dll)
  done
}

case "$OS_KIND" in
  linux)   bundle_linux ;;
  macos)   bundle_macos ;;
  windows) bundle_windows ;;
esac

# ── 4. Strip debug symbols from the copies (keep originals in the build dir
#      untouched) ────────────────────────────────────────────────────────────
if [[ "$OS_KIND" != "windows" ]]; then
  for f in "${BIN_FILES[@]}" "$DIST_ROOT"/lib/*; do
    [[ -f "$f" && ! -L "$f" ]] || continue
    strip --strip-unneeded "$f" 2>/dev/null || strip -x "$f" 2>/dev/null || true
  done
fi

# ── 5. Archive ────────────────────────────────────────────────────────────────
mkdir -p "$OPT_OUT"
if [[ "$OS_KIND" == "windows" ]]; then
  OUT_FILE="$OPT_OUT/$OPT_NAME.zip"
  ( cd "$STAGE_DIR" && zip -qr "$(cd "$OPT_OUT" && pwd)/$(basename "$OUT_FILE")" "$OPT_NAME" )
else
  OUT_FILE="$OPT_OUT/$OPT_NAME.tar.gz"
  tar -czf "$OUT_FILE" -C "$STAGE_DIR" "$OPT_NAME"
fi

rm -rf "$STAGE_DIR"
echo "==> Done: $OUT_FILE ($(du -sh "$OUT_FILE" | cut -f1))"
